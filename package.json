{
  "name": "openclaw-plugin-data-guard",
  "version": "2.0.3",
  "description": "AI 数据隐私护盾 — 双层数据脱敏插件（HTTP 代理层 + 工具调用层）。纯 Node.js，零外部依赖，数据不离开本机。",
  "type": "module",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlanSong2077/openclaw-plugins-data-guard"
  },
  "homepage": "https://github.com/AlanSong2077/openclaw-plugins-data-guard#readme",
  "exports": {
    ".": "./index.js",
    "./core/desensitize": "./src/core/desensitize.js",
    "./plugins/base/Plugin": "./src/plugins/base/Plugin.js",
    "./plugins/base/ToolPlugin": "./src/plugins/base/ToolPlugin.js",
    "./plugins/tool/formats": "./src/plugins/tool/formats/index.js",
    "./plugins/tool/formats/FileFormat": "./src/plugins/tool/formats/FileFormat.js",
    "./plugins/tool/formats/CsvFormat": "./src/plugins/tool/formats/CsvFormat.js",
    "./plugins/tool/formats/XlsxFormat": "./src/plugins/tool/formats/XlsxFormat.js",
    "./plugins/tool/formats/XlsFormat": "./src/plugins/tool/formats/XlsFormat.js",
    "./plugins/tool/FileDesensitizePlugin": "./src/plugins/tool/FileDesensitizePlugin.js",
    "./plugins/ProxyPlugin": "./src/plugins/ProxyPlugin.js",
    "./input/FileReader": "./src/input/FileReader.js",
    "./output/TempFileManager": "./src/output/TempFileManager.js",
    "./proxy/ProxyServer": "./src/proxy/ProxyServer.js",
    "./proxy/UrlRewriter": "./src/proxy/UrlRewriter.js"
  },
  "files": [
    "index.js",
    "src/",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "data-guard",
    "desensitization",
    "privacy",
    "proxy",
    "file-guard",
    "csv",
    "xlsx",
    "xls"
  ],
  "license": "MIT",
  "author": "Alan Song",
  "contributors": [
    "Roxy Li"
  ],
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "scripts": {
    "test":         "node test/index.js",
    "test:core":    "node test/index.js --only core",
    "test:formats": "node test/index.js --only formats",
    "test:input":   "node test/index.js --only input",
    "test:output":  "node test/index.js --only output",
    "test:proxy":   "node test/index.js --only proxy",
    "test:plugins": "node test/index.js --only plugins",
    "test:bail":    "node test/index.js --bail",
    "pack":         "npm pack && openclaw plugins install openclaw-plugin-data-guard",
    "postinstall":  "npm run pack"
  }
}
